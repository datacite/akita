    "build": "next build",
    "start": "next start",
    "type-check": "tsc",
    "prettier-format": "prettier --config .prettierrc.json '**/*.ts|tsx' --write",
    "lint": "./node_modules/.bin/eslint . --ext .ts,.tsx",
    "cy:coverage": "npx nyc report --reporter=lcov",
    "cy:open": "cypress open",
    "cy:run": "cypress run",
    "cy:run:record": "cypress run --record --quiet"
  },
  "nyc": {
    "reporter": [
      "html"
    ]
  },
